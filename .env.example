# PostgreSQL connection string (used for WNBA persistence and for NBA/G-League workers)
# Set this in Railway to your Postgres URL to push scraped WNBA data to the database.
# Example: postgresql://user:password@host:port/railway
DATABASE_URL=postgresql://localhost:5432/nba

# Which league this worker/job generator serves: nba or gleague
# Workers only claim jobs where league = SCRAPER_LEAGUE.
SCRAPER_LEAGUE=gleague
